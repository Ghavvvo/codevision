---
// Testimonials Section Component
---

<section id="testimonials" class="py-24 bg-white">
  <div class="container mx-auto px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-primary-dark mb-6">
        Lo que Dicen Nuestros Clientes
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        La satisfacción de nuestros clientes es nuestro mayor logro. Aquí tienes algunas de sus experiencias trabajando con nosotros.
      </p>
    </div>

    <!-- Testimonials Carousel -->
    <div class="relative max-w-4xl mx-auto">
      <div class="testimonial-container overflow-hidden">
        <div class="testimonial-slider flex transition-transform duration-500 ease-in-out" id="testimonial-slider">
          <!-- Testimonial 1 -->
          <div class="testimonial-slide flex-shrink-0 w-full px-4">
            <div class="text-center reveal">
              <div class="mb-8">
                <img src="https://picsum.photos/80/80?random=11" alt="Cliente 1" class="w-20 h-20 rounded-full mx-auto mb-6 shadow-lg">
                <div class="flex justify-center mb-6">
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                </div>
                <blockquote class="text-xl md:text-2xl text-gray-700 font-medium leading-relaxed mb-6 italic">
                  "CodeVision transformó completamente nuestra presencia digital. Su equipo no solo entendió nuestra visión, sino que la superó con una aplicación web increíble que ha aumentado nuestras ventas un 150%."
                </blockquote>
                <h4 class="text-lg font-display font-semibold text-primary-dark mb-1">
                  Laura Fernández
                </h4>
                <p class="text-primary-blue">CEO, TechStart Solutions</p>
              </div>
            </div>
          </div>

          <!-- Testimonial 2 -->
          <div class="testimonial-slide flex-shrink-0 w-full px-4">
            <div class="text-center">
              <div class="mb-8">
                <img src="https://picsum.photos/80/80?random=12" alt="Cliente 2" class="w-20 h-20 rounded-full mx-auto mb-6 shadow-lg">
                <div class="flex justify-center mb-6">
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                </div>
                <blockquote class="text-xl md:text-2xl text-gray-700 font-medium leading-relaxed mb-6 italic">
                  "La aplicación móvil que desarrollaron para nosotros es simplemente espectacular. El diseño es elegante, la funcionalidad es perfecta y nuestros usuarios la adoran. Superaron todas nuestras expectativas."
                </blockquote>
                <h4 class="text-lg font-display font-semibold text-primary-dark mb-1">
                  Miguel Rodríguez
                </h4>
                <p class="text-primary-blue">Founder, HealthTech Pro</p>
              </div>
            </div>
          </div>

          <!-- Testimonial 3 -->
          <div class="testimonial-slide flex-shrink-0 w-full px-4">
            <div class="text-center">
              <div class="mb-8">
                <img src="https://picsum.photos/80/80?random=13" alt="Cliente 3" class="w-20 h-20 rounded-full mx-auto mb-6 shadow-lg">
                <div class="flex justify-center mb-6">
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                </div>
                <blockquote class="text-xl md:text-2xl text-gray-700 font-medium leading-relaxed mb-6 italic">
                  "Trabajar con CodeVision ha sido una experiencia excepcional. Su profesionalismo, creatividad y capacidad técnica nos ayudaron a lanzar nuestro e-commerce en tiempo récord. Los recomiendo al 100%."
                </blockquote>
                <h4 class="text-lg font-display font-semibold text-primary-dark mb-1">
                  Carmen Silva
                </h4>
                <p class="text-primary-blue">Director de Marketing, Fashion Store</p>
              </div>
            </div>
          </div>

          <!-- Testimonial 4 -->
          <div class="testimonial-slide flex-shrink-0 w-full px-4">
            <div class="text-center">
              <div class="mb-8">
                <img src="https://picsum.photos/80/80?random=14" alt="Cliente 4" class="w-20 h-20 rounded-full mx-auto mb-6 shadow-lg">
                <div class="flex justify-center mb-6">
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                  <i class="las la-star text-yellow-400 text-xl"></i>
                </div>
                <blockquote class="text-xl md:text-2xl text-gray-700 font-medium leading-relaxed mb-6 italic">
                  "La plataforma IoT que desarrollaron revolucionó nuestros procesos industriales. Su expertise técnico y atención al detalle son incomparables. Definitivamente volveremos a trabajar con ellos."
                </blockquote>
                <h4 class="text-lg font-display font-semibold text-primary-dark mb-1">
                  Roberto Jiménez
                </h4>
                <p class="text-primary-blue">CTO, Industrial Dynamics</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Navigation Buttons -->
      <button class="absolute left-4 top-1/2 transform -translate-y-1/2 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center hover:bg-gray-50 transition-colors" id="prev-testimonial">
        <i class="las la-chevron-left text-primary-dark text-xl"></i>
      </button>
      <button class="absolute right-4 top-1/2 transform -translate-y-1/2 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center hover:bg-gray-50 transition-colors" id="next-testimonial">
        <i class="las la-chevron-right text-primary-dark text-xl"></i>
      </button>

      <!-- Indicators -->
      <div class="flex justify-center mt-8 space-x-2" id="testimonial-indicators">
        <button class="w-3 h-3 rounded-full bg-primary-turquoise"></button>
        <button class="w-3 h-3 rounded-full bg-gray-300"></button>
        <button class="w-3 h-3 rounded-full bg-gray-300"></button>
        <button class="w-3 h-3 rounded-full bg-gray-300"></button>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="text-center mt-16 reveal">
      <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4">
        ¿Listo para ser nuestro próximo caso de éxito?
      </h3>
      <p class="text-lg text-gray-600 mb-8">
        Únete a las empresas que han confiado en CodeVision para transformar sus ideas en realidad digital
      </p>
      <a href="#contact" class="btn-hover inline-flex items-center px-8 py-4 bg-primary-blue text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300">
        <i class="las la-handshake mr-3"></i>
        Empezar mi Proyecto
      </a>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('testimonial-slider');
    const prevBtn = document.getElementById('prev-testimonial');
    const nextBtn = document.getElementById('next-testimonial');
    const indicators = document.querySelectorAll('#testimonial-indicators button');
    
    let currentSlide = 0;
    const totalSlides = 4;
    
    const updateSlider = () => {
      const translateX = -currentSlide * 100;
      slider.style.transform = `translateX(${translateX}%)`;
      
      // Update indicators
      indicators.forEach((indicator, index) => {
        indicator.classList.toggle('bg-primary-turquoise', index === currentSlide);
        indicator.classList.toggle('bg-gray-300', index !== currentSlide);
      });
    };
    
    const nextSlide = () => {
      currentSlide = (currentSlide + 1) % totalSlides;
      updateSlider();
    };
    
    const prevSlide = () => {
      currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
      updateSlider();
    };
    
    // Event listeners
    nextBtn.addEventListener('click', nextSlide);
    prevBtn.addEventListener('click', prevSlide);
    
    indicators.forEach((indicator, index) => {
      indicator.addEventListener('click', () => {
        currentSlide = index;
        updateSlider();
      });
    });
    
    // Auto-slide every 5 seconds
    setInterval(nextSlide, 5000);
  });
</script>