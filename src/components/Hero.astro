---
// Hero Section Component
---

<section class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-primary-dark to-primary-blue overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="0.05"%3E%3Ccircle cx="7" cy="7" r="1"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')] opacity-20"></div>
  
  <!-- Floating Elements -->
  <div class="absolute top-20 left-20 w-20 h-20 bg-primary-turquoise rounded-full opacity-20 animate-float"></div>
  <div class="absolute top-40 right-32 w-12 h-12 bg-primary-orange rounded-full opacity-30 animate-float" style="animation-delay: -1s;"></div>
  <div class="absolute bottom-32 left-1/4 w-16 h-16 bg-primary-turquoise rounded-full opacity-15 animate-float" style="animation-delay: -2s;"></div>

  <div class="container mx-auto px-8 text-center relative z-10">
    <div class="max-w-4xl mx-auto">
      <!-- Main Headline -->
      <h1 class="text-5xl md:text-7xl font-display font-bold text-white mb-8 leading-tight">
        <span class="block">Transformamos</span>
        <span class="block text-primary-turquoise" id="typewriter-text"></span>
        <span class="block">en soluciones digitales</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-xl md:text-2xl text-gray-200 mb-12 max-w-3xl mx-auto leading-relaxed reveal" style="opacity: 0;">
        Somos CodeVision, tu socio estratégico en desarrollo de software. Creamos aplicaciones web y móviles que impulsan el crecimiento de tu negocio.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center reveal" style="opacity: 0;">
        <a href="#contact" class="btn-hover inline-flex items-center px-8 py-4 bg-primary-orange text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 text-lg">
          <i class="las la-rocket mr-3 text-xl"></i>
          Comenzar Proyecto
        </a>
        <a href="#services" class="btn-hover inline-flex items-center px-8 py-4 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-primary-dark transition-all duration-300 text-lg">
          <i class="las la-play-circle mr-3 text-xl"></i>
          Ver Servicios
        </a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-8 mt-16 reveal" style="opacity: 0;">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-primary-turquoise mb-2">100+</div>
          <div class="text-gray-300">Proyectos Completados</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-primary-turquoise mb-2">5+</div>
          <div class="text-gray-300">Años de Experiencia</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-primary-turquoise mb-2">50+</div>
          <div class="text-gray-300">Clientes Satisfechos</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->

</section>

<script>
  import { animations } from '../utils/animations.js';
  
  document.addEventListener('DOMContentLoaded', () => {
    // Initialize typewriter effect
    const typewriterText = document.getElementById('typewriter-text');
    if (typewriterText) {
      const texts = ['ideas', 'conceptos', 'visiones'];
      let currentIndex = 0;
      
      const typeNextText = () => {
        animations.typeWriter(typewriterText, texts[currentIndex], 0.5);
        currentIndex = (currentIndex + 1) % texts.length;
      };
      
      typeNextText();
      setInterval(typeNextText, 3000);
    }
  });
</script>