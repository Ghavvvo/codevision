---
// Services Section Component
---

<section id="services" class="py-24 bg-gray-50">
  <div class="container mx-auto px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-primary-dark mb-6">
        Nuestros Servicios
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Ofrecemos soluciones tecnológicas integrales para impulsar tu negocio hacia el futuro digital
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-parent">
      <!-- Web Development -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-blue rounded-lg flex items-center justify-center mb-6">
          <i class="las la-code text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4">
          Desarrollo Web
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed">
          Aplicaciones web modernas y responsivas usando las últimas tecnologías como React, Vue, Node.js y Python.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Frontend Responsivo
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            APIs RESTful
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Bases de Datos
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          Más información <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>

      <!-- Mobile Development -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-turquoise rounded-lg flex items-center justify-center mb-6">
          <i class="las la-mobile text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4">
          Apps Móviles
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed">
          Desarrollo de aplicaciones móviles nativas e híbridas para iOS y Android con experiencia de usuario excepcional.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            iOS & Android
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            React Native
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Flutter
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          Más información <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>

      <!-- Data Science -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-orange rounded-lg flex items-center justify-center mb-6">
          <i class="las la-chart-line text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4">
          Ciencia de Datos
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed">
          Obtén valor de tus datos con análisis avanzados, modelos predictivos y visualizaciones accionables.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Análisis Exploratorio (EDA)
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Modelos de Machine Learning
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Dashboards & BI
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          Más información <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>

      <!-- E-commerce -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-blue rounded-lg flex items-center justify-center mb-6">
          <i class="las la-shopping-cart text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4">
          E-commerce
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed">
          Tiendas online completas con pasarelas de pago, gestión de inventarios y analytics avanzados.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Shopify & WooCommerce
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Pagos Seguros
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            SEO Optimizado
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          Más información <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>

      <!-- UI/UX Design -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-turquoise rounded-lg flex items-center justify-center mb-6">
          <i class="las la-paint-brush text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4">
          Diseño UI/UX
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed">
          Diseños centrados en el usuario que maximizan la conversión y mejoran la experiencia digital.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Prototipado
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Testing Usuario
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Design Systems
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          Más información <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>

      <!-- Consulting -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-orange rounded-lg flex items-center justify-center mb-6">
          <i class="las la-lightbulb text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4">
          Consultoría Tech
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed">
          Asesoramiento estratégico en tecnología para optimizar procesos y acelerar la transformación digital.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Auditoría Técnica
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Arquitectura Software
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            Roadmap Tecnológico
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          Más información <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>
    </div>
  </div>
</section>