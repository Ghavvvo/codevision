---
// Services Section Component
---

<section id="services" class="py-24 bg-gray-50">
  <div class="container mx-auto px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-primary-dark mb-6" data-i18n="services.title">
        Nuestros Servicios
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto" data-i18n="services.subtitle">
        Ofrecemos soluciones tecnológicas integrales para impulsar tu negocio hacia el futuro digital
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-parent">
      <!-- Web Development -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-blue rounded-lg flex items-center justify-center mb-6">
          <i class="las la-code text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4" data-i18n="services.web.title">
          Desarrollo Web
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed" data-i18n="services.web.description">
          Aplicaciones web modernas y responsivas usando las últimas tecnologías como React, Vue, Node.js y Python.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.web.features.frontend">Frontend Responsivo</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.web.features.api">APIs RESTful</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.web.features.database">Bases de Datos</span>
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          <span data-i18n="services.moreInfo">Más información</span> <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>

      <!-- Mobile Development -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-turquoise rounded-lg flex items-center justify-center mb-6">
          <i class="las la-mobile text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4" data-i18n="services.mobile.title">
          Apps Móviles
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed" data-i18n="services.mobile.description">
          Desarrollo de aplicaciones móviles nativas e híbridas para iOS y Android con experiencia de usuario excepcional.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.mobile.features.platforms">iOS & Android</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.mobile.features.reactNative">React Native</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.mobile.features.flutter">Flutter</span>
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          <span data-i18n="services.moreInfo">Más información</span> <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>

      <!-- Data Science -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-orange rounded-lg flex items-center justify-center mb-6">
          <i class="las la-chart-line text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4" data-i18n="services.data.title">
          Ciencia de Datos
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed" data-i18n="services.data.description">
          Obtén valor de tus datos con análisis avanzados, modelos predictivos y visualizaciones accionables.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.data.features.eda">Análisis Exploratorio (EDA)</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.data.features.ml">Modelos de Machine Learning</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.data.features.bi">Dashboards & BI</span>
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          <span data-i18n="services.moreInfo">Más información</span> <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>

      <!-- E-commerce -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-blue rounded-lg flex items-center justify-center mb-6">
          <i class="las la-shopping-cart text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4" data-i18n="services.ecommerce.title">
          E-commerce
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed" data-i18n="services.ecommerce.description">
          Tiendas online completas con pasarelas de pago, gestión de inventarios y analytics avanzados.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.ecommerce.features.platforms">Shopify & WooCommerce</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.ecommerce.features.payments">Pagos Seguros</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.ecommerce.features.seo">SEO Optimizado</span>
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          <span data-i18n="services.moreInfo">Más información</span> <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>

      <!-- UI/UX Design -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-turquoise rounded-lg flex items-center justify-center mb-6">
          <i class="las la-paint-brush text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4" data-i18n="services.uiux.title">
          Diseño UI/UX
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed" data-i18n="services.uiux.description">
          Diseños centrados en el usuario que maximizan la conversión y mejoran la experiencia digital.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.uiux.features.prototyping">Prototipado</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.uiux.features.testing">Testing Usuario</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.uiux.features.design">Design Systems</span>
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          <span data-i18n="services.moreInfo">Más información</span> <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>

      <!-- Consulting -->
      <div class="stagger-child card-hover bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-primary-orange rounded-lg flex items-center justify-center mb-6">
          <i class="las la-lightbulb text-white text-2xl"></i>
        </div>
        <h3 class="text-2xl font-display font-semibold text-primary-dark mb-4" data-i18n="services.consulting.title">
          Consultoría Tech
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed" data-i18n="services.consulting.description">
          Asesoramiento estratégico en tecnología para optimizar procesos y acelerar la transformación digital.
        </p>
        <ul class="space-y-2 mb-6">
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.consulting.features.audit">Auditoría Técnica</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.consulting.features.architecture">Arquitectura Software</span>
          </li>
          <li class="flex items-center text-gray-600">
            <i class="las la-check text-primary-turquoise mr-3"></i>
            <span data-i18n="services.consulting.features.roadmap">Roadmap Tecnológico</span>
          </li>
        </ul>
        <a href="#contact" class="inline-flex items-center text-primary-blue font-semibold hover:text-primary-dark transition-colors">
          <span data-i18n="services.moreInfo">Más información</span> <i class="las la-arrow-right ml-2"></i>
        </a>
      </div>
    </div>
  </div>
</section>