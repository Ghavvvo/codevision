---
// About Section Component
---

<section id="about" class="py-24 bg-gray-50">
  <div class="container mx-auto px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-primary-dark mb-6">
        Acerca de CodeVision
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Somos un equipo apasionado de desarrolladores y diseñadores comprometidos con la excelencia tecnológica
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Content -->
      <div class="reveal">
        <h3 class="text-3xl font-display font-semibold text-primary-dark mb-6">
          Nuestra Misión
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed text-lg">
          En CodeVision, creemos que la tecnología debe servir para simplificar y mejorar la vida de las personas. Nos especializamos en convertir ideas complejas en soluciones digitales elegantes y funcionales.
        </p>
        <p class="text-gray-600 mb-8 leading-relaxed text-lg">
          Desde 2019, hemos ayudado a más de 50 empresas a transformar digitalmente sus procesos, creando aplicaciones web y móviles que no solo cumplen, sino que superan las expectativas.
        </p>

        <!-- Values -->
        <div class="space-y-4">
          <div class="flex items-start">
            <div class="w-8 h-8 bg-primary-turquoise rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
              <i class="las la-rocket text-white text-sm"></i>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-primary-dark mb-2">Innovación Constante</h4>
              <p class="text-gray-600">Siempre estamos explorando nuevas tecnologías para ofrecer las mejores soluciones.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-8 h-8 bg-primary-blue rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
              <i class="las la-heart text-white text-sm"></i>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-primary-dark mb-2">Pasión por la Calidad</h4>
              <p class="text-gray-600">Cada línea de código es escrita con dedicación y atención al detalle.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-8 h-8 bg-primary-orange rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
              <i class="las la-users text-white text-sm"></i>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-primary-dark mb-2">Colaboración Transparente</h4>
              <p class="text-gray-600">Trabajamos de la mano contigo en cada etapa del proyecto.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Team Grid -->
      <div class="reveal">
        <div class="grid grid-cols-2 gap-6">
          <!-- Team Member 1 -->
          <div class="text-center">
            <div class="relative mb-4">
              <img src="https://picsum.photos/150/150?random=7" alt="CEO" class="w-24 h-24 rounded-full mx-auto shadow-lg">
              <div class="absolute inset-0 w-24 h-24 rounded-full mx-auto bg-gradient-to-tr from-primary-turquoise to-primary-blue opacity-20"></div>
            </div>
            <h4 class="text-lg font-display font-semibold text-primary-dark mb-1">Ana García</h4>
            <p class="text-primary-blue font-medium mb-2">CEO & Founder</p>
            <div class="flex justify-center space-x-2">
              <a href="#" class="text-gray-400 hover:text-primary-blue transition-colors">
                <i class="lab la-linkedin text-lg"></i>
              </a>
              <a href="#" class="text-gray-400 hover:text-primary-blue transition-colors">
                <i class="lab la-twitter text-lg"></i>
              </a>
            </div>
          </div>

          <!-- Team Member 2 -->
          <div class="text-center">
            <div class="relative mb-4">
              <img src="https://picsum.photos/150/150?random=8" alt="CTO" class="w-24 h-24 rounded-full mx-auto shadow-lg">
              <div class="absolute inset-0 w-24 h-24 rounded-full mx-auto bg-gradient-to-tr from-primary-turquoise to-primary-blue opacity-20"></div>
            </div>
            <h4 class="text-lg font-display font-semibold text-primary-dark mb-1">Carlos Ruiz</h4>
            <p class="text-primary-blue font-medium mb-2">CTO</p>
            <div class="flex justify-center space-x-2">
              <a href="#" class="text-gray-400 hover:text-primary-blue transition-colors">
                <i class="lab la-linkedin text-lg"></i>
              </a>
              <a href="#" class="text-gray-400 hover:text-primary-blue transition-colors">
                <i class="lab la-github text-lg"></i>
              </a>
            </div>
          </div>

          <!-- Team Member 3 -->
          <div class="text-center">
            <div class="relative mb-4">
              <img src="https://picsum.photos/150/150?random=9" alt="Lead Developer" class="w-24 h-24 rounded-full mx-auto shadow-lg">
              <div class="absolute inset-0 w-24 h-24 rounded-full mx-auto bg-gradient-to-tr from-primary-turquoise to-primary-blue opacity-20"></div>
            </div>
            <h4 class="text-lg font-display font-semibold text-primary-dark mb-1">María López</h4>
            <p class="text-primary-blue font-medium mb-2">Lead Developer</p>
            <div class="flex justify-center space-x-2">
              <a href="#" class="text-gray-400 hover:text-primary-blue transition-colors">
                <i class="lab la-linkedin text-lg"></i>
              </a>
              <a href="#" class="text-gray-400 hover:text-primary-blue transition-colors">
                <i class="lab la-dribbble text-lg"></i>
              </a>
            </div>
          </div>

          <!-- Team Member 4 -->
          <div class="text-center">
            <div class="relative mb-4">
              <img src="https://picsum.photos/150/150?random=10" alt="UX Designer" class="w-24 h-24 rounded-full mx-auto shadow-lg">
              <div class="absolute inset-0 w-24 h-24 rounded-full mx-auto bg-gradient-to-tr from-primary-turquoise to-primary-blue opacity-20"></div>
            </div>
            <h4 class="text-lg font-display font-semibold text-primary-dark mb-1">David Martín</h4>
            <p class="text-primary-blue font-medium mb-2">UX Designer</p>
            <div class="flex justify-center space-x-2">
              <a href="#" class="text-gray-400 hover:text-primary-blue transition-colors">
                <i class="lab la-linkedin text-lg"></i>
              </a>
              <a href="#" class="text-gray-400 hover:text-primary-blue transition-colors">
                <i class="lab la-behance text-lg"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 mt-12 text-center">
          <div>
            <div class="text-2xl font-bold text-primary-turquoise mb-1">5+</div>
            <div class="text-gray-600 text-sm">Años de Experiencia</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-primary-turquoise mb-1">50+</div>
            <div class="text-gray-600 text-sm">Proyectos Entregados</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-primary-turquoise mb-1">98%</div>
            <div class="text-gray-600 text-sm">Satisfacción Cliente</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Technologies -->
    <div class="mt-24 reveal">
      <h3 class="text-2xl font-display font-semibold text-primary-dark text-center mb-12">
        Tecnologías que Dominamos
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-8 items-center opacity-60">
        <div class="flex justify-center">
          <i class="lab la-react text-4xl text-primary-blue"></i>
        </div>
        <div class="flex justify-center">
          <i class="lab la-vue text-4xl text-primary-blue"></i>
        </div>
        <div class="flex justify-center">
          <i class="lab la-angular text-4xl text-primary-blue"></i>
        </div>
        <div class="flex justify-center">
          <i class="lab la-node-js text-4xl text-primary-blue"></i>
        </div>
        <div class="flex justify-center">
          <i class="lab la-python text-4xl text-primary-blue"></i>
        </div>
        <div class="flex justify-center">
          <i class="lab la-aws text-4xl text-primary-blue"></i>
        </div>
        <div class="flex justify-center">
          <i class="lab la-docker text-4xl text-primary-blue"></i>
        </div>
        <div class="flex justify-center">
          <i class="lab la-figma text-4xl text-primary-blue"></i>
        </div>
      </div>
    </div>
  </div>
</section>