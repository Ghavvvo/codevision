---
// About Section Component
import TeamIllustration from "../assets/illustrations/about-team.svg";
---

<section id="about" class="py-24 bg-gray-50">
  <div class="container mx-auto px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-primary-dark mb-6">
        Acerca de CodeVision
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Somos un equipo apasionado de desarrolladores y diseñadores comprometidos con la excelencia tecnológica
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Content -->
      <div class="reveal">
        <h3 class="text-3xl font-display text-center font-semibold text-primary-dark mb-6">
          Nuestra Misión
        </h3>
        <p class="text-gray-600 mb-6 leading-relaxed text-lg">
          En CodeVision, creemos que la tecnología debe servir para simplificar y mejorar la vida de las personas. Nos especializamos en convertir ideas complejas en soluciones digitales elegantes y funcionales.
        </p>


        <!-- Values -->
        <div class="space-y-4">
          <div class="flex items-start">
            <div class="w-8 h-8 bg-primary-turquoise rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
              <i class="las la-rocket text-white text-sm"></i>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-primary-dark mb-2">Innovación Constante</h4>
              <p class="text-gray-600">Siempre estamos explorando nuevas tecnologías para ofrecer las mejores soluciones.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-8 h-8 bg-primary-blue rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
              <i class="las la-heart text-white text-sm"></i>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-primary-dark mb-2">Pasión por la Calidad</h4>
              <p class="text-gray-600">Cada línea de código es escrita con dedicación y atención al detalle.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-8 h-8 bg-primary-orange rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
              <i class="las la-users text-white text-sm"></i>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-primary-dark mb-2">Colaboración Transparente</h4>
              <p class="text-gray-600">Trabajamos de la mano contigo en cada etapa del proyecto.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Team Grid -->
      <div class="reveal">
        <div class="relative">
          <!-- Main Illustration -->
          <div class="bg-gradient-to-br from-primary-turquoise/5 via-primary-blue/5 to-primary-orange/5 rounded-3xl p-4 md:p-8 flex items-center justify-center">
            <img src={TeamIllustration.src} alt="Equipo colaborando en CodeVision" loading="lazy" decoding="async" class="w-full max-w-xl md:max-w-2xl h-auto drop-shadow-xl select-none pointer-events-none" />
          </div>
        </div>
      </div>


    </div>

    <!-- Technologies -->
    <div class="mt-24 reveal">
      <h3 class="text-2xl font-display font-semibold text-primary-dark text-center mb-12">
        Tecnologías que Dominamos
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-8 items-center opacity-60">
        <div class="flex justify-center"><i class="lab la-html5 text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-css3-alt text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-js text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-react text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-vuejs text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-swift text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-node-js text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-python text-4xl text-primary-blue"></i></div>

        <div class="flex justify-center"><i class="lab la-node text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-java text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-git text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-github text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-gitlab text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-wordpress text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-docker text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-aws text-4xl text-primary-blue"></i></div>

        <div class="flex justify-center"><i class="lab la-next-js text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-linux text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-android text-4xl text-primary-blue"></i></div>
        <div class="flex justify-center"><i class="lab la-figma text-4xl text-primary-blue"></i></div>
      </div>
    </div>
  </div>
</section>