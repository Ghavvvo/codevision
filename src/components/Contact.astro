---
// Contact Section Component
---

<section id="contact" class="py-24 bg-gray-50">
  <div class="container mx-auto px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-primary-dark mb-6">
        Hablemos de tu Proyecto
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Estamos listos para convertir tu visión en una solución digital exitosa. Cuéntanos sobre tu proyecto y te ayudaremos a hacerlo realidad.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-12">
      <!-- Contact Info -->
      <div class="lg:col-span-1 reveal">
        <div class="bg-primary-dark rounded-lg p-8 text-white">
          <h3 class="text-2xl font-display font-semibold mb-8">
            Información de Contacto
          </h3>

          <div class="space-y-6">
            <!-- Email -->
            <div class="flex items-start">
              <div class="w-8 h-8 bg-primary-turquoise rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
                <i class="las la-envelope text-white text-sm"></i>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Email</h4>
                <a href="mailto:hola@codevision.com" class="text-gray-300 hover:text-primary-turquoise transition-colors">
                  hola@codevision.com
                </a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start">
              <div class="w-8 h-8 bg-primary-turquoise rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
                <i class="las la-phone text-white text-sm"></i>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Teléfono</h4>
                <a href="tel:+34912345678" class="text-gray-300 hover:text-primary-turquoise transition-colors">
                  +34 912 345 678
                </a>
              </div>
            </div>

            <!-- Address -->
            <div class="flex items-start">
              <div class="w-8 h-8 bg-primary-turquoise rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
                <i class="las la-map-marker-alt text-white text-sm"></i>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Oficina</h4>
                <p class="text-gray-300">
                  Calle Innovation 123<br>
                  28001 Madrid, España
                </p>
              </div>
            </div>

            <!-- Schedule -->
            <div class="flex items-start">
              <div class="w-8 h-8 bg-primary-turquoise rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
                <i class="las la-clock text-white text-sm"></i>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Horario</h4>
                <p class="text-gray-300">
                  Lun - Vie: 9:00 - 18:00<br>
                  Sáb: 10:00 - 14:00
                </p>
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div class="mt-12 pt-8 border-t border-gray-700">
            <h4 class="font-semibold mb-4">Síguenos</h4>
            <div class="flex space-x-4">
              <a href="#" class="w-10 h-10 bg-primary-turquoise rounded-full flex items-center justify-center hover:bg-white hover:text-primary-dark transition-all duration-300">
                <i class="lab la-linkedin text-lg"></i>
              </a>
              <a href="#" class="w-10 h-10 bg-primary-turquoise rounded-full flex items-center justify-center hover:bg-white hover:text-primary-dark transition-all duration-300">
                <i class="lab la-twitter text-lg"></i>
              </a>
              <a href="#" class="w-10 h-10 bg-primary-turquoise rounded-full flex items-center justify-center hover:bg-white hover:text-primary-dark transition-all duration-300">
                <i class="lab la-github text-lg"></i>
              </a>
              <a href="#" class="w-10 h-10 bg-primary-turquoise rounded-full flex items-center justify-center hover:bg-white hover:text-primary-dark transition-all duration-300">
                <i class="lab la-dribbble text-lg"></i>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-2 reveal">
        <div class="bg-white rounded-lg shadow-lg p-8">
          <form class="space-y-6" id="contact-form">
            <!-- Name and Email -->
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
                  Nombre *
                </label>
                <input type="text" id="name" name="name" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-turquoise focus:border-transparent transition-all duration-300">
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                  Email *
                </label>
                <input type="email" id="email" name="email" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-turquoise focus:border-transparent transition-all duration-300">
              </div>
            </div>

            <!-- Title -->
            <div>
              <label for="title" class="block text-sm font-medium text-gray-700 mb-2">
                Título *
              </label>
              <input type="text" id="title" name="title" required
                     placeholder="Asunto de tu consulta"
                     class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-turquoise focus:border-transparent transition-all duration-300">
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
                Mensaje *
              </label>
              <textarea id="message" name="message" rows="5" required
                        placeholder="Escribe tu mensaje aquí..."
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-turquoise focus:border-transparent transition-all duration-300"></textarea>
            </div>

            <!-- Submit Button -->
            <div class="pt-4">
              <button type="submit"
                      class="btn-hover w-full bg-primary-orange text-white font-semibold py-4 px-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center">
                <i class="las la-paper-plane mr-3"></i>
                <span>Enviar Mensaje</span>
                <div class="loading-spinner hidden ml-3">
                  <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white"></div>
                </div>
              </button>
            </div>
          </form>

          <!-- Success Message -->
          <div id="success-message" class="hidden mt-6 p-4 bg-green-100 border border-green-300 rounded-lg">
            <div class="flex items-center">
              <i class="las la-check-circle text-green-600 text-xl mr-3"></i>
              <p class="text-green-700">
                ¡Gracias por tu mensaje! Nos pondremos en contacto contigo en las próximas 24 horas.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import emailjs from '@emailjs/browser';

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    const submitBtn = form.querySelector('button[type="submit"]');
    const btnText = submitBtn.querySelector('span');
    const loadingSpinner = submitBtn.querySelector('.loading-spinner');
    const successMessage = document.getElementById('success-message');
    const publicKey = 'bQvDFbtWpp4k1AIz7'
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Show loading state
      btnText.textContent = 'Enviando...';

      emailjs.sendForm('service_40wm9gh', 'template_swlrtm6',form, {
            publicKey: publicKey,
          })
          .then(
             async () => {

                // Simulate form submission (replace with actual API call)
                await new Promise(resolve => setTimeout(resolve, 2000));

                // Show success message
                successMessage.classList.remove('hidden');
                form.reset();

                // Hide success message after 5 seconds
                setTimeout(() => {
                  successMessage.classList.add('hidden');
                }, 5000);

                console.log('SUCCESS!');
              },
              (error) => {
                console.log(publicKey)
                console.log('FAILED...', error.text);
              },
          );
      loadingSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      // Reset button state
      btnText.textContent = 'Enviar Mensaje';
      loadingSpinner.classList.add('hidden');
      submitBtn.disabled = false;


    });
  });
</script>