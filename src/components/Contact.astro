---
// Contact Section Component
---

<section id="contact" class="py-24 bg-gray-50">
  <div class="container mx-auto px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-primary-dark mb-6" data-i18n="contact.title">
        Hablemos de tu Proyecto
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto" data-i18n="contact.subtitle">
        Estamos listos para convertir tu visión en una solución digital exitosa. Cuéntanos sobre tu proyecto y te ayudaremos a hacerlo realidad.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-12">

       <!-- Contact Form -->
      <div class="lg:col-span-2 reveal">
        <div class="bg-white rounded-lg shadow-lg p-8">
          <form class="space-y-6" id="contact-form">
            <!-- Name and Email -->
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="contact.form.name">
                  Nombre
                </label>
                <input type="text" id="name" name="name" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-turquoise focus:border-transparent transition-all duration-300">
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="contact.form.email">
                  Email
                </label>
                <input type="email" id="email" name="email" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-turquoise focus:border-transparent transition-all duration-300">
              </div>
            </div>

            <!-- Title -->
            <div>
              <label for="title" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="contact.form.title">
                Título
              </label>
              <input type="text" id="title" name="title" required
                     placeholder="Asunto de tu consulta"
                     class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-turquoise focus:border-transparent transition-all duration-300">
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="contact.form.message">
                Mensaje
              </label>
              <textarea id="message" name="message" rows="5" required
                        placeholder="Escribe tu mensaje aquí..."
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-turquoise focus:border-transparent transition-all duration-300"></textarea>
            </div>

            <!-- Submit Button -->
            <div class="pt-4">
              <button type="submit"
                      class="btn-hover w-full bg-primary-orange text-white font-semibold py-4 px-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center">
                <i class="las la-paper-plane mr-3"></i>
                <span data-i18n="contact.form.send">Enviar Mensaje</span>
                <span class="loading-spinner hidden ml-3">
                  <i class="las la-spinner la-spin"></i>
                </span>
              </button>
            </div>
          </form>

          <!-- Success Message -->
          <div id="success-message" class="hidden mt-6 p-4 bg-green-100 border border-green-300 rounded-lg">
            <div class="flex items-center">
              <i class="las la-check-circle text-green-600 text-xl mr-3"></i>
              <p class="text-green-700" data-i18n="contact.form.success">
                ¡Gracias por tu mensaje! Nos pondremos en contacto contigo en las próximas 24 horas.
              </p>
            </div>
          </div>

          <!-- Error Message -->
          <div id="error-message" class="hidden mt-6 p-4 bg-red-100 border border-red-300 rounded-lg">
            <div class="flex items-center">
              <i class="las la-exclamation-circle text-red-600 text-xl mr-3"></i>
              <p class="text-red-700" data-i18n="contact.form.error">
                Hubo un error al enviar tu mensaje. Por favor, inténtalo de nuevo.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Info -->
      <div id="contact-info" class="lg:col-span-1 reveal">
        <div class="bg-primary-dark rounded-lg p-8 text-white">
          <h3 class="text-2xl font-display font-semibold mb-8" data-i18n="contact.info.title">
            Información de Contacto
          </h3>

          <div class="space-y-6">
            <!-- Phone -->
            <div class="flex items-start">
              <div class="w-8 h-8 bg-primary-turquoise rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
                <i class="las la-phone text-white text-sm"></i>
              </div>
              <div>
                <h4 class="font-semibold mb-1" data-i18n="contact.info.phone">Teléfono</h4>
                <a href="tel:+5354792549" class="text-gray-300 hover:text-primary-turquoise transition-colors">
                  +53 54792549
                </a>
              </div>
            </div>

            <!-- Schedule -->
            <div class="flex items-start">
              <div class="w-8 h-8 bg-primary-turquoise rounded-full flex items-center justify-center flex-shrink-0 mr-4 mt-1">
                <i class="las la-clock text-white text-sm"></i>
              </div>
              <div>
                <h4 class="font-semibold mb-1" data-i18n="contact.info.schedule">Horario</h4>
                <p class="text-gray-300" id="schedule-text">
                  Lun - Vie: 9:00 - 18:00<br>
                  Sáb: 10:00 - 14:00
                </p>
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div class="mt-12 pt-8 border-t border-gray-700">
            <h4 class="font-semibold mb-4"></h4>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import emailjs from '@emailjs/browser';
  import { getTranslations } from '../utils/i18n.js';

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const btnText = submitBtn?.querySelector('span[data-i18n]') as HTMLSpanElement | null;
    const loadingSpinner = submitBtn?.querySelector('.loading-spinner') as HTMLElement | null;
    const successMessage = document.getElementById('success-message') as HTMLElement | null;
    const errorMessage = document.getElementById('error-message') as HTMLElement | null;
    const publicKey = 'bQvDFbtWpp4k1AIz7';

    if (!form || !submitBtn || !btnText || !loadingSpinner || !successMessage || !errorMessage) {
      console.error('No se pudieron encontrar los elementos del formulario');
      return;
    }

    let currentLang = localStorage.getItem('language') || 'en';

    // Función para mostrar estado de carga
    const showLoadingState = () => {
      const t = getTranslations(currentLang);
      btnText.textContent = t.contact.form.sending;
      loadingSpinner.classList.remove('hidden');
      submitBtn.disabled = true;
    };

    // Función para restaurar estado normal del botón
    const resetButtonState = () => {
      const t = getTranslations(currentLang);
      btnText.textContent = t.contact.form.send;
      loadingSpinner.classList.add('hidden');
      submitBtn.disabled = false;
    };

    // Función para mostrar mensaje de éxito
    const showSuccessMessage = () => {
      successMessage.classList.remove('hidden');
      errorMessage.classList.add('hidden');
      form.reset();

      // Ocultar mensaje después de 5 segundos
      setTimeout(() => {
        successMessage.classList.add('hidden');
      }, 5000);
    };

    // Función para mostrar mensaje de error
    const showErrorMessage = () => {
      errorMessage.classList.remove('hidden');
      successMessage.classList.add('hidden');

      // Ocultar mensaje después de 5 segundos
      setTimeout(() => {
        errorMessage.classList.add('hidden');
      }, 5000);
    };

    // Actualizar placeholders y textos cuando cambie el idioma
    const updateTexts = () => {
      const t = getTranslations(currentLang);
      const titleInput = document.getElementById('title') as HTMLInputElement;
      const messageInput = document.getElementById('message') as HTMLTextAreaElement;
      const scheduleText = document.getElementById('schedule-text');

      if (titleInput) {
        titleInput.placeholder = t.contact.form.titlePlaceholder;
      }
      if (messageInput) {
        messageInput.placeholder = t.contact.form.messagePlaceholder;
      }
      if (scheduleText) {
        scheduleText.innerHTML = t.contact.info.scheduleText.replace(/\n/g, '<br>');
      }
    };

    // Escuchar cambios de idioma
    window.addEventListener('languageChange', ((event: CustomEvent) => {
      currentLang = event.detail.lang;
      updateTexts();
      resetButtonState();
    }) as EventListener);

    // Inicializar textos
    updateTexts();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      try {
        // Mostrar estado de carga
        showLoadingState();

        // Enviar formulario con EmailJS
        await emailjs.sendForm('service_40wm9gh', 'template_swlrtm6', form, {
          publicKey: publicKey,
        });

        console.log('Mensaje enviado exitosamente');

        // Mostrar mensaje de éxito
        showSuccessMessage();

      } catch (error) {
        console.error('Error al enviar mensaje:', error);

        // Mostrar mensaje de error
        showErrorMessage();

      } finally {
        // Siempre restaurar el estado del botón
        resetButtonState();
      }
    });
  });
</script>

