---
// Footer Component
---

<footer class="bg-primary-dark text-white">
  <!-- Main Footer -->
  <div class="container mx-auto px-8 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div>
        <div class="flex items-center mb-6">
          <div class="w-10 h-10 bg-primary-turquoise rounded-lg flex items-center justify-center mr-3">
            <i class="las la-code text-white text-xl"></i>
          </div>
          <span class="text-2xl font-display font-bold">CodeVision</span>
        </div>
        <p class="text-gray-300 mb-6 leading-relaxed" data-i18n="footer.description">
          Transformamos ideas en soluciones digitales innovadoras. Tu socio estratégico en desarrollo de software.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-lg font-display font-semibold mb-6" data-i18n="footer.services">Servicios</h3>
        <ul class="space-y-3">
          <li>
            <a href="#services" class="text-gray-300 hover:text-primary-turquoise transition-colors duration-300 flex items-center">
              <i class="las la-angle-right mr-2"></i>
              <span data-i18n="footer.links.webDev">Desarrollo Web</span>
            </a>
          </li>
          <li>
            <a href="#services" class="text-gray-300 hover:text-primary-turquoise transition-colors duration-300 flex items-center">
              <i class="las la-angle-right mr-2"></i>
              <span data-i18n="footer.links.mobileApps">Aplicaciones Móviles</span>
            </a>
          </li>
          <li>
            <a href="#services" class="text-gray-300 hover:text-primary-turquoise transition-colors duration-300 flex items-center">
              <i class="las la-angle-right mr-2"></i>
              <span data-i18n="footer.links.dataScience">Ciencia de Datos</span>
            </a>
          </li>
          <li>
            <a href="#services" class="text-gray-300 hover:text-primary-turquoise transition-colors duration-300 flex items-center">
              <i class="las la-angle-right mr-2"></i>
              <span data-i18n="footer.links.ecommerce">E-commerce</span>
            </a>
          </li>
          <li>
            <a href="#services" class="text-gray-300 hover:text-primary-turquoise transition-colors duration-300 flex items-center">
              <i class="las la-angle-right mr-2"></i>
              <span data-i18n="footer.links.uiux">Diseño UI/UX</span>
            </a>
          </li>
          <li>
            <a href="#services" class="text-gray-300 hover:text-primary-turquoise transition-colors duration-300 flex items-center">
              <i class="las la-angle-right mr-2"></i>
              <span data-i18n="footer.links.consulting">Consultoría Tech</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-lg font-display font-semibold mb-6" data-i18n="footer.company">Empresa</h3>
        <ul class="space-y-3">
          <li>
            <a href="#about" class="text-gray-300 hover:text-primary-turquoise transition-colors duration-300 flex items-center">
              <i class="las la-angle-right mr-2"></i>
              <span data-i18n="footer.links.aboutUs">Acerca de Nosotros</span>
            </a>
          </li>
          <li>
            <a href="#contact" class="text-gray-300 hover:text-primary-turquoise transition-colors duration-300 flex items-center">
              <i class="las la-angle-right mr-2"></i>
              <span data-i18n="footer.links.contact">Contacto</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-display font-semibold mb-6" data-i18n="footer.contact">Contacto</h3>
        <div class="space-y-4">
          <div class="flex items-center">
            <i class="las la-phone text-primary-turquoise mr-3"></i>
            <a href="tel:+5354702549" class="text-gray-300 hover:text-primary-turquoise transition-colors">
              +53 54702549
            </a>
          </div>

          <div class="flex items-center">
            <i class="las la-envelope text-primary-turquoise mr-3"></i>
            <a href="mailto:developers.codevision@gmail.com" class="text-gray-300 hover:text-primary-turquoise transition-colors break-all">
              developers.codevision@gmail.com
            </a>
          </div>

          <div class="flex items-center">
            <i class="las la-clock text-primary-turquoise mr-3"></i>
            <div class="text-gray-300">
              <p data-i18n="footer.scheduleText">Lun - Vie: 9:00 - 18:00<br>Sáb: 10:00 - 14:00</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-700">
    <div class="container mx-auto px-8 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="text-gray-300 text-sm mb-4 md:mb-0">
          <p>&copy; 2026 CodeVision. <span data-i18n="footer.rights">Todos los derechos reservados</span>.</p>
        </div>

      </div>
    </div>
  </div>
</footer>

<!-- WhatsApp Floating Button -->
<a
  href="https://wa.me/5354702549?text=Hola%20CodeVision%2C%20me%20gustar%C3%ADa%20obtener%20m%C3%A1s%20informaci%C3%B3n%20sobre%20sus%20servicios."
  target="_blank"
  rel="noopener noreferrer"
  id="whatsapp-btn"
  class="fixed bottom-8 right-8 w-14 h-14 bg-green-500 hover:bg-green-600 text-white rounded-full shadow-lg z-50 flex items-center justify-center transition-all duration-300"
  aria-label="Contactar por WhatsApp">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<style>
  #whatsapp-btn {
    animation: whatsapp-glow 2s ease-in-out infinite;
  }

  #whatsapp-btn:hover {
    animation: none;
    box-shadow: 0 0 20px rgba(34, 197, 94, 0.8), 0 0 40px rgba(34, 197, 94, 0.4);
    transform: scale(1.1);
  }

  @keyframes whatsapp-glow {
    0%, 100% {
      box-shadow: 0 0 8px rgba(34, 197, 94, 0.5), 0 0 16px rgba(34, 197, 94, 0.3);
    }
    50% {
      box-shadow: 0 0 16px rgba(34, 197, 94, 0.8), 0 0 32px rgba(34, 197, 94, 0.5), 0 0 48px rgba(34, 197, 94, 0.2);
    }
  }
</style>