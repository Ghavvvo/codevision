---
// Projects Section Component
---

<section id="projects" class="py-24 bg-white">
  <div class="container mx-auto px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-primary-dark mb-6" data-i18n="projects.title">
        Proyectos Destacados
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto" data-i18n="projects.subtitle">
        Algunos de nuestros trabajos más recientes que demuestran nuestra experiencia y creatividad
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-parent">
      <!-- Project 1 -->
      <div class="stagger-child group relative overflow-hidden rounded-lg shadow-lg card-hover">
        <div class="aspect-w-16 aspect-h-10">
          <img src="https://picsum.photos/400/250?random=1" alt="E-commerce Platform" class="w-full h-64 object-cover parallax transition-transform duration-300 group-hover:scale-110">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-primary-dark via-transparent to-transparent opacity-0 group-hover:opacity-90 transition-opacity duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 transform translate-y-full group-hover:translate-y-0 transition-transform duration-300">
          <h3 class="text-xl font-display font-semibold text-white mb-2" data-i18n="projects.items.ecommerce.title">
            Plataforma E-commerce
          </h3>
          <p class="text-gray-200 mb-4 text-sm" data-i18n="projects.items.ecommerce.description">
            Sistema completo de comercio electrónico con gestión de inventarios y analytics
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">React</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Node.js</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">MongoDB</span>
          </div>
          <a href="#" class="inline-flex items-center text-primary-turquoise font-semibold hover:text-white transition-colors">
            <span data-i18n="projects.viewProject">Ver proyecto</span> <i class="las la-external-link-alt ml-2"></i>
          </a>
        </div>
      </div>

      <!-- Project 2 -->
      <div class="stagger-child group relative overflow-hidden rounded-lg shadow-lg card-hover">
        <div class="aspect-w-16 aspect-h-10">
          <img src="https://picsum.photos/400/250?random=2" alt="Mobile Banking App" class="w-full h-64 object-cover parallax transition-transform duration-300 group-hover:scale-110">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-primary-dark via-transparent to-transparent opacity-0 group-hover:opacity-90 transition-opacity duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 transform translate-y-full group-hover:translate-y-0 transition-transform duration-300">
          <h3 class="text-xl font-display font-semibold text-white mb-2" data-i18n="projects.items.banking.title">
            App Bancaria Móvil
          </h3>
          <p class="text-gray-200 mb-4 text-sm" data-i18n="projects.items.banking.description">
            Aplicación móvil segura para servicios bancarios con autenticación biométrica
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">React Native</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Python</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">AWS</span>
          </div>
          <a href="#" class="inline-flex items-center text-primary-turquoise font-semibold hover:text-white transition-colors">
            <span data-i18n="projects.viewProject">Ver proyecto</span> <i class="las la-external-link-alt ml-2"></i>
          </a>
        </div>
      </div>

      <!-- Project 3 -->
      <div class="stagger-child group relative overflow-hidden rounded-lg shadow-lg card-hover">
        <div class="aspect-w-16 aspect-h-10">
          <img src="https://picsum.photos/400/250?random=3" alt="Healthcare Dashboard" class="w-full h-64 object-cover parallax transition-transform duration-300 group-hover:scale-110">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-primary-dark via-transparent to-transparent opacity-0 group-hover:opacity-90 transition-opacity duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 transform translate-y-full group-hover:translate-y-0 transition-transform duration-300">
          <h3 class="text-xl font-display font-semibold text-white mb-2" data-i18n="projects.items.healthcare.title">
            Dashboard Médico
          </h3>
          <p class="text-gray-200 mb-4 text-sm" data-i18n="projects.items.healthcare.description">
            Sistema de gestión hospitalaria con seguimiento de pacientes en tiempo real
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Vue.js</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Django</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">PostgreSQL</span>
          </div>
          <a href="#" class="inline-flex items-center text-primary-turquoise font-semibold hover:text-white transition-colors">
            <span data-i18n="projects.viewProject">Ver proyecto</span> <i class="las la-external-link-alt ml-2"></i>
          </a>
        </div>
      </div>

      <!-- Project 4 -->
      <div class="stagger-child group relative overflow-hidden rounded-lg shadow-lg card-hover">
        <div class="aspect-w-16 aspect-h-10">
          <img src="https://picsum.photos/400/250?random=4" alt="IoT Platform" class="w-full h-64 object-cover parallax transition-transform duration-300 group-hover:scale-110">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-primary-dark via-transparent to-transparent opacity-0 group-hover:opacity-90 transition-opacity duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 transform translate-y-full group-hover:translate-y-0 transition-transform duration-300">
          <h3 class="text-xl font-display font-semibold text-white mb-2" data-i18n="projects.items.iot.title">
            Plataforma IoT
          </h3>
          <p class="text-gray-200 mb-4 text-sm" data-i18n="projects.items.iot.description">
            Sistema de monitoreo industrial con sensores IoT y alertas automáticas
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Angular</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Express</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">InfluxDB</span>
          </div>
          <a href="#" class="inline-flex items-center text-primary-turquoise font-semibold hover:text-white transition-colors">
            <span data-i18n="projects.viewProject">Ver proyecto</span> <i class="las la-external-link-alt ml-2"></i>
          </a>
        </div>
      </div>

      <!-- Project 5 -->
      <div class="stagger-child group relative overflow-hidden rounded-lg shadow-lg card-hover">
        <div class="aspect-w-16 aspect-h-10">
          <img src="https://picsum.photos/400/250?random=5" alt="Learning Management System" class="w-full h-64 object-cover parallax transition-transform duration-300 group-hover:scale-110">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-primary-dark via-transparent to-transparent opacity-0 group-hover:opacity-90 transition-opacity duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 transform translate-y-full group-hover:translate-y-0 transition-transform duration-300">
          <h3 class="text-xl font-display font-semibold text-white mb-2" data-i18n="projects.items.learning.title">
            Plataforma E-Learning
          </h3>
          <p class="text-gray-200 mb-4 text-sm" data-i18n="projects.items.learning.description">
            Sistema de aprendizaje online con videoconferencias y seguimiento de progreso
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Next.js</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">NestJS</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Redis</span>
          </div>
          <a href="#" class="inline-flex items-center text-primary-turquoise font-semibold hover:text-white transition-colors">
            <span data-i18n="projects.viewProject">Ver proyecto</span> <i class="las la-external-link-alt ml-2"></i>
          </a>
        </div>
      </div>

      <!-- Project 6 -->
      <div class="stagger-child group relative overflow-hidden rounded-lg shadow-lg card-hover">
        <div class="aspect-w-16 aspect-h-10">
          <img src="https://picsum.photos/400/250?random=6" alt="Fintech Solution" class="w-full h-64 object-cover parallax transition-transform duration-300 group-hover:scale-110">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-primary-dark via-transparent to-transparent opacity-0 group-hover:opacity-90 transition-opacity duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 transform translate-y-full group-hover:translate-y-0 transition-transform duration-300">
          <h3 class="text-xl font-display font-semibold text-white mb-2" data-i18n="projects.items.fintech.title">
            Solución Fintech
          </h3>
          <p class="text-gray-200 mb-4 text-sm" data-i18n="projects.items.fintech.description">
            Plataforma de pagos digitales con blockchain y criptomonedas
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Svelte</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Go</span>
            <span class="px-2 py-1 bg-primary-turquoise text-white text-xs rounded">Blockchain</span>
          </div>
          <a href="#" class="inline-flex items-center text-primary-turquoise font-semibold hover:text-white transition-colors">
            <span data-i18n="projects.viewProject">Ver proyecto</span> <i class="las la-external-link-alt ml-2"></i>
          </a>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="text-center mt-16 reveal">
      <p class="text-lg text-gray-600 mb-8" data-i18n="projects.cta.text">
        ¿Tienes un proyecto en mente? Hablemos sobre cómo podemos hacerlo realidad
      </p>
      <a href="#contact" class="btn-hover inline-flex items-center px-8 py-4 bg-primary-orange text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300">
        <i class="las la-comments mr-3"></i>
        <span data-i18n="projects.cta.button">Discutir tu Proyecto</span>
      </a>
    </div>
  </div>
</section>